---
// src/layouts/Layout.astro
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ここでTailwindを読み込みます */
  @import "tailwindcss";

  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    /* 背景色を少しグレーにするとモダンに見えます */
    @apply bg-white text-slate-900;
  }
</style>
---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
    const projects = [
        {
            id: "owe-manager",
            title: "Owe Manager",
            tech: ["TypeScript", "Next.js", "Hono", "Cloudflare D1"],
            description: "借金の管理をもっとスマートに。シンプルなインターフェースで日々の貸し借りを可視化します。",
            details: "大学生活での小さな貸し借りをストレスなく管理するために制作した「Owe Manager」。「誰に、いくら、いつまでに」返すべきかを明確化し、現在の合計未返済額を一目で把握できます。バックエンドにはCloudflare D1とHonoを採用し、エッジでの高速なレスポンスを実現しています。",
            github: "https://github.com/aoma-ikegaki/owe-manager",
            link: "https://42dc705f.owe-manager-web.pages.dev/",
            images: ["/owe-manager.png"]
        },
        {
            id: "Smart Kanji",
            title: "Smart 幹事",
            tech: ["Python", "Fast API", "TypeScript", "React", "MySQL"],
            description: "幹事の「めんどくさい」をゼロに。日程もお店も、LINEで完結。",
            details: "ハッカソンで開発した、幹事のためのLINEボット「Smart 幹事」。ユーザーはLINE上で日程調整やお店選びを行うだけで、幹事の仕事が完了します。バックエンドはPythonとFast APIで構築し、フロントエンドはReactで実装しました。",
            github: "https://github.com/have4blast/schedule-coordinator-bot",
            images: [
                "/smart-kanji.png",
                "/スクリーンショット 2026-02-28 234412.png",
                "/スクリーンショット 2026-02-28 235521.png",
                "/スクリーンショット 2026-02-28 234502.png",
                "/スクリーンショット 2026-02-28 234518.png"
            ]
        }
    ];

    return projects.map((project) => ({
        params: { id: project.id },
        props: { project },
    }));
}

const { project } = Astro.props;
---

<Layout title={project.title}>
    <main class="min-h-screen bg-white font-sans text-slate-800">
        <div class="max-w-4xl mx-auto px-6 py-20">
            <a href="/" class="inline-flex items-center gap-2 text-slate-400 hover:text-slate-900 transition-colors mb-12 group">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Back to Portfolio
            </a>

            <div class="space-y-12">
                <div class="relative group/carousel">
                    <button id="prev-btn" class="absolute left-4 top-1/2 -track-y-1/2 z-10 p-3 rounded-full bg-white/90 shadow-lg text-slate-800 opacity-0 group-hover/carousel:opacity-100 transition-all hover:bg-white hover:scale-110 disabled:hidden hidden md:flex border border-slate-100" aria-label="Previous image">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                        </svg>
                    </button>

                    <div id="carousel-track" class="flex overflow-x-auto gap-6 pb-8 snap-x snap-mandatory scroll-smooth no-scrollbar" transition:name={`image-${project.id}`}>
                        {project.images.map((img: string, index: number) => (
                            <div class={`flex-none w-full md:w-[100%] snap-center flex justify-center ${index === 0 ? 'ml-0' : ''} ${index === project.images.length - 1 ? 'mr-0' : ''}`}>
                                <div class="w-full rounded-3xl overflow-hidden border border-slate-100 shadow-xl bg-white transition-transform duration-500 hover:scale-[1.01]">
                                    <img 
                                        src={img} 
                                        alt={project.title} 
                                        class="w-full h-auto aspect-[16/9] object-contain bg-slate-50"
                                        draggable="false"
                                    />
                                </div>
                            </div>
                        ))}
                    </div>

                    <button id="next-btn" class="absolute right-4 top-1/2 -translate-y-1/2 z-10 p-3 rounded-full bg-white/90 shadow-lg text-slate-800 opacity-0 group-hover/carousel:opacity-100 transition-all hover:bg-white hover:scale-110 disabled:hidden hidden md:flex border border-slate-100" aria-label="Next image">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </button>
                    
                    {/* スクロールを促すヒント（任意） */}
                    <div class="absolute inset-y-0 right-0 w-20 bg-gradient-to-l from-white/80 to-transparent pointer-events-none md:hidden"></div>
                </div>

                <script>
                    function initCarousel() {
                        const track = document.getElementById('carousel-track');
                        const prevBtn = document.getElementById('prev-btn');
                        const nextBtn = document.getElementById('next-btn');

                        if (!track || !prevBtn || !nextBtn) return;

                        const scrollAmount = track.offsetWidth * 0.8;

                        prevBtn.addEventListener('click', () => {
                            track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
                        });

                        nextBtn.addEventListener('click', () => {
                            track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
                        });

                        // 最初の画像/最後の画像でボタンを隠す等の制御
                        const updateButtons = () => {
                            prevBtn.style.display = track.scrollLeft <= 0 ? 'none' : 'flex';
                            nextBtn.style.display = 
                                (track.scrollLeft + track.offsetWidth >= track.scrollWidth - 10) ? 'none' : 'flex';
                        };

                        track.addEventListener('scroll', updateButtons);
                        window.addEventListener('resize', updateButtons);
                        updateButtons();
                    }

                    // View Transitions 用のライフサイクルイベント
                    document.addEventListener('astro:page-load', initCarousel);
                </script>

                <style>
                    .no-scrollbar::-webkit-scrollbar {
                        display: none;
                    }
                    .no-scrollbar {
                        -ms-overflow-style: none; /* IE and Edge */
                        scrollbar-width: none; /* Firefox */
                    }
                </style>

                <div class="max-w-2xl mx-auto space-y-8">
                    <div transition:name={`content-${project.id}`}>
                        <h1 class="text-5xl font-black text-slate-900 tracking-tight">{project.title}</h1>
                        <div class="flex flex-wrap gap-2 mt-6">
                            {project.tech.map((t: string) => (
                                <span class="bg-blue-50 text-blue-600 text-xs px-4 py-1.5 rounded-full font-bold border border-blue-100">{t}</span>
                            ))}
                        </div>
                    </div>

                    <div class="prose prose-slate lg:prose-xl max-w-none">
                        <p class="text-xl text-slate-600 leading-relaxed font-medium">
                            {project.details}
                        </p>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-4 pt-8">
                        <a href={project.github} target="_blank" rel="noopener noreferrer" class="flex-1 bg-slate-100 text-slate-900 rounded-2xl py-4 font-bold hover:bg-slate-200 transition-all text-center flex items-center justify-center gap-3">
                            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                            GitHub Repository
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </main>
</Layout>

---
import Layout from '../layouts/Layout.astro';

const projects = [
    {
        id: "owe-manager",
        title: "Owe Manager",
        tech: ["TypeScript", "Next.js", "Hono", "Cloudflare D1"],
        description: "借金の管理をもっとスマートに。シンプルなインターフェースで日々の貸し借りを可視化します。",
        details: "大学生活での小さな貸し借りをストレスなく管理するために制作した「Owe Manager」。「誰に、いくら、いつまでに」返すべきかを明確化し、現在の合計未返済額を一目で把握できます。バックエンドにはCloudflare D1とHonoを採用し、エッジでの高速なレスポンスを実現しています。",
        github: "https://github.com/aoma-ikegaki/owe-manager",
        link: "https://42dc705f.owe-manager-web.pages.dev/",
        images: [
            "/owe-manager.png"
        ]
    },
    {
        id: "Smart Kanji",
        title: "Smart Kanji",
        tech: ["Python", "Fast API", "TypeScript", "React", "MySQL"],
        description: "幹事の「めんどくさい」をゼロに。日程もお店も、LINEで完結。",
        details: "ハッカソンで開発した、幹事のためのLINEボット「Smart 幹事」。ユーザーはLINE上で日程調整やお店選びを行うだけで、幹事の仕事が完了します。バックエンドはPythonとFast APIで構築し、フロントエンドはReactで実装しました。",
        github: "https://github.com/have4blast/schedule-coordinator-bot",
        images: [
            "/smart-kanji.png"
        ]
    },

];


const timeline = [
    {
        period: "2025.12 - 2026.01",
        title: "サポーターズ主催 ハッカソン 努力賞",
        description: "サポーターズ主催のハッカソンに参加し、努力賞を受賞しました。"
    },
    {
        period: "2024.04 - now",
        title: "徳島大学 理工学部 理工学科 光システムコース",
        description: "大学2年。光工学と情報工学の基礎を学んでいます。"
    },
];
---
<Layout title="My Portfolio">
    <main class="min-h-screen bg-gradient-to-br from-blue-200 to-green-200 px-6 py-20 font-sans text-slate-800">
        <div class="max-w-3xl mx-auto space-y-12">
            
            <!-- 自己紹介カード -->
            <section class="bg-white/70 backdrop-blur-md rounded-3xl p-10 shadow-sm border border-white">
                <div class="flex flex-col md:flex-row justify-between items-start gap-6">
                    <div>
                        <h2 class="text-xs font-bold tracking-widest text-slate-400 uppercase mb-4">Self Introduction</h2>
                        <h1 class="text-4xl font-black text-slate-900 mb-4">aoma ikegaki</h1>
                        <p class="leading-relaxed text-slate-600">
                            徳島大学 理工学部 理工学科 光システムコース 2年
                        </p>
                        <div class="mt-6 flex items-center gap-2 text-slate-500 hover:text-blue-500 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                            <a href="mailto:aoma8270@gmail.com" class="text-sm font-medium">aoma8270@gmail.com</a>
                        </div>
                    </div>
                    <div class="flex gap-4">
                        <a href="https://github.com/aoma-ikegaki" target="_blank" rel="noopener noreferrer" class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white border border-slate-100 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all text-slate-600 hover:text-slate-900" title="GitHub">
                            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                        </a>
                        <a href="https://x.com/aoma4eqn" target="_blank" rel="noopener noreferrer" class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white border border-slate-100 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all text-slate-600 hover:text-black" title="X">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932 6.064-6.932zm-1.292 19.49h2.039L6.486 3.24H4.298l13.311 17.403z"/></svg>
                        </a>
                    </div>
                </div>
            </section>

            <!-- タイムライン (経歴) -->
            <section class="bg-white/70 backdrop-blur-md rounded-3xl p-10 shadow-sm border border-white">
                <h2 class="text-xs font-bold tracking-widest text-slate-400 uppercase mb-6">Timeline</h2>
                <div class="space-y-8">
                    {timeline.map((item) => (
                        <div class="flex flex-col sm:flex-row gap-2 sm:gap-6 border-l-2 border-slate-100 pl-6 relative">
                            <div class="absolute w-3 h-3 bg-blue-400 rounded-full -left-[7px] top-1.5 border-2 border-white shadow-sm"></div>
                            <span class="text-sm font-mono text-slate-400 shrink-0 sm:w-32">{item.period}</span>
                            <div>
                                <h3 class="font-bold text-slate-900">{item.title}</h3>
                                <p class="text-sm text-slate-600 mt-2 leading-relaxed">
                                    {item.description}
                                </p>
                            </div>
                        </div>
                    ))}
                </div>
            </section>

            <!-- 成果物 (Projects) -->
            <section class="bg-white/70 backdrop-blur-md rounded-3xl p-10 shadow-sm border border-white">
                <h2 class="text-xs font-bold tracking-widest text-slate-400 uppercase mb-6">Projects</h2>
                
                <div class="grid gap-10">
                    {projects.map((project) => (
                        <a 
                            href={`/project/${project.id}`}
                            class="project-card group flex flex-col md:flex-row gap-6 text-left w-full cursor-pointer hover:bg-white/40 p-4 -m-4 rounded-2xl transition-all"
                        >
                            <div class="w-full md:w-48 h-32 shrink-0 overflow-hidden rounded-xl bg-slate-100 border border-slate-200">
                                <img 
                                    src={project.images[0]} 
                                    alt={project.title} 
                                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                    transition:name={`image-${project.id}`}
                                />
                            </div>
                            <div class="flex-1">
                                <h3 class="font-bold group-hover:text-blue-500 transition-colors text-xl flex items-center gap-2">
                                    <span transition:name={`title-${project.id}`}>{project.title}</span>
                                    <object>
                                        <a 
                                            href={project.github} 
                                            target="_blank" 
                                            rel="noopener noreferrer" 
                                            class="text-slate-400 hover:text-slate-900 transition-colors p-1"
                                            onclick="event.stopPropagation()"
                                        >
                                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.43.372.823 1.102.823 2.222 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                                            </svg>
                                        </a>
                                    </object>
                                </h3>
                                <div class="flex flex-wrap gap-2 mt-2">
                                    {project.tech.map(tech => (
                                        <span class="bg-blue-50 text-blue-600 text-[10px] px-2 py-0.5 rounded-full font-medium">{tech}</span>
                                    ))}
                                </div>
                                <p class="mt-3 text-sm text-slate-600 leading-relaxed line-clamp-2">
                                    {project.description}
                                </p>
                                <div class="mt-6 flex items-center justify-between">
                                    <span class="text-xs font-bold text-blue-500 group-hover:translate-x-1 transition-transform">
                                        Read Details →
                                    </span>
                                    {project.link && (
                                        <object>
                                        <a 
                                            href={project.link} 
                                            target="_blank" 
                                            rel="noopener noreferrer" 
                                            class="text-sm font-bold text-blue-600 bg-blue-50 hover:bg-blue-100 px-4 py-2 rounded-xl transition-all flex items-center gap-2 group/link shadow-sm border border-blue-100"
                                            onclick="event.stopPropagation()"
                                        >
                                            Visit App
                                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover/link:translate-y-[-1px] group-hover/link:translate-x-[1px] transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                            </svg>
                                        </a>
                                        </object>
                                    )}
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            </section>

            
            <!-- 記事 (Articles) -->
            <section class="bg-white/70 backdrop-blur-md rounded-3xl p-10 shadow-sm border border-white">
                <h2 class="text-xs font-bold tracking-widest text-slate-400 uppercase mb-6">Articles</h2>
                <ul class="list-disc list-inside space-y-3">
                    <li>
                        <a href="#" class="text-sm hover:underline text-slate-600 italic">記事１</a>
                    </li>
                    <li>
                        <a href="#" class="text-sm hover:underline text-slate-600 italic">記事２</a>
                    </li>
                    <li>
                        <a href="#" class="text-sm hover:underline text-slate-600 italic">記事３</a>
                    </li>
                </ul>
            </section>

        </div>
    </main>
</Layout>